# ── Astra AI — backend environment template ──────────────────
# Copy this file to `.env` and fill in your own values.
# `.env` itself is gitignored — never commit real secrets.

APP_NAME=Astra AI — SolarOps AI Assistant
SECRET_KEY=change-me-to-a-long-random-string-in-production

# ── LLM ─────────────────────────────────────────────────────
# Recommended: Groq (free + fast). Get a key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=openai/gpt-oss-120b
GROQ_FALLBACK_MODEL=openai/gpt-oss-20b

# Optional alternative (paid): OpenAI
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_MODEL=gpt-4o-mini

# ── Usage limits ─────────────────────────────────────────────
# Per-user, per-model daily budgets live in the model registry:
# backend/app/usage.py → MODELS (4 models, spent best-first).

# FAQ semantic cache — min cosine similarity to serve a cached answer (0 tokens)
FAQ_SIM_THRESHOLD=0.72

# ── Paths (defaults are fine for local dev) ─────────────────
CHROMA_DB_PATH=./chroma_db
DOCS_UPLOAD_PATH=../data/sop-documents

# ── Production only ───────────────────────────────────────────
# Comma-separated extra CORS origins (e.g. your Vercel URL)
# ALLOWED_ORIGINS=https://your-app.vercel.app
